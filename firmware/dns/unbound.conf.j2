server:
    verbosity: 1
    interface: 0.0.0.0
    port: 53
    access-control: 192.168.0.0/16 allow
    access-control: 10.0.0.0/8 allow
    access-control: 172.16.0.0/12 allow
    do-ip4: yes
    do-ip6: no
    hide-identity: yes
    hide-version: yes
    prefetch: yes
{% for domain in domains %}
    local-zone: "{{ domain }}." always_nxdomain
{% endfor %}

forward-zone:
    name: "."
    forward-addr: 1.1.1.1
    forward-addr: 9.9.9.9
